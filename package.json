{
  "name": "cds-debug",
  "displayName": "CDS Debug",
  "description": "Debug multiple SAP CAP services simultaneously via Cloud Foundry integration",
  "version": "0.0.11",
  "icon": "resources/icon.png",
  "publisher": "dongtran",
  "repository": {
    "type": "git",
    "url": "https://github.com/dongitran/cds-debug"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cds-debug",
          "title": "CDS Debug",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "cds-debug": [
        {
          "type": "webview",
          "id": "cdsDebug.mainView",
          "name": "Debug Launcher"
        }
      ]
    },
    "commands": [
      {
        "command": "cdsDebug.resetConfig",
        "title": "CDS Debug: Reset Configuration"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --max-warnings=0",
    "cspell": "cspell '**/*.{ts,json,md}' --no-progress",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vscode/vsce": "^3.0.0",
    "cspell": "^9.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
